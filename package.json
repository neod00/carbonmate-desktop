{
  "name": "lca-desktop",
  "version": "0.0.1",
  "private": true,
  "description": "CarbonMate desktop app + license server monorepo",
  "scripts": {
    "dev:desktop": "pnpm --filter @lca/desktop dev",
    "dev:server": "pnpm --filter @lca/license-server dev",
    "build:desktop": "pnpm --filter @lca/desktop build",
    "build:server": "pnpm --filter @lca/license-server build",
    "build:shared": "pnpm --filter @lca/shared build",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  }
}
