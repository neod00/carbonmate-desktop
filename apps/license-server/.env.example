# Neon Postgres (Vercel 마켓플레이스에서 자동 주입)
DATABASE_URL=

# 라이선스 응답 HMAC 서명용 비밀키 (랜덤 64바이트 hex)
# 생성: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
LICENSE_SIGNING_SECRET=

# Admin 페이지 비밀번호 (Phase 0 임시)
ADMIN_PASSWORD=

# Gemini API 키 (AI 프록시용)
GEMINI_API_KEY=

# Resend API 키 (라이선스 키 이메일 발송)
RESEND_API_KEY=

# 데이터 파일 베이스 URL (보통 자기 자신)
DATA_BASE_URL=https://your-license-server.vercel.app/data
